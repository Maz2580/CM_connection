FACTORY_DEF * RoutingFactory   FACTORY_NAME "Router and Unexpected Input Remover"   COMMAND_PARM_EVALUATION SINGLE_PASS   INPUT FEATURE_TYPE *    ROUTE XLSXR "XLSXR_1::Program Summary" multi_reader_keyword,$(DATASET_KEYWORD_XLSXR_1) TO FME_GENERIC "::Program Summary" ALIAS_GEOMETRY    ROUTE XLSXR "XLSXR_1::Gravel Path Renewal Program" multi_reader_keyword,$(DATASET_KEYWORD_XLSXR_1) TO FME_GENERIC "::Gravel Path Renewal Program" ALIAS_GEOMETRY    ROUTE XLSXR XLSXR_3::Summary multi_reader_keyword,$(DATASET_KEYWORD_XLSXR_3) TO FME_GENERIC ::Summary ALIAS_GEOMETRY    ROUTE XLSXR XLSXR_3::Detailed multi_reader_keyword,$(DATASET_KEYWORD_XLSXR_3) TO FME_GENERIC ::Detailed ALIAS_GEOMETRY    ROUTE XLSXR XLSXR_6::Deleted multi_reader_keyword,$(DATASET_KEYWORD_XLSXR_6) TO FME_GENERIC ::Deleted ALIAS_GEOMETRY    ROUTE XLSXR XLSXR_7::Deleted multi_reader_keyword,$(DATASET_KEYWORD_XLSXR_7) TO FME_GENERIC ::Deleted ALIAS_GEOMETRY    ROUTE XLSXR "XLSXR_8::Removed from program" multi_reader_keyword,$(DATASET_KEYWORD_XLSXR_8) TO FME_GENERIC "::Removed from program" ALIAS_GEOMETRY    ROUTE XLSXR "XLSXR_8::Unit Rates" multi_reader_keyword,$(DATASET_KEYWORD_XLSXR_8) TO FME_GENERIC "::Unit Rates" ALIAS_GEOMETRY    ROUTE XLSXR XLSXR_9::Sheet1 multi_reader_keyword,$(DATASET_KEYWORD_XLSXR_9) TO FME_GENERIC ::Sheet1 ALIAS_GEOMETRY    ROUTE XLSXR XLSXR_10::Sheet1 multi_reader_keyword,$(DATASET_KEYWORD_XLSXR_10) TO FME_GENERIC ::Sheet1 ALIAS_GEOMETRY    ROUTE XLSXR "XLSXR_11::Shared Path Renewal Program" multi_reader_keyword,$(DATASET_KEYWORD_XLSXR_11) TO FME_GENERIC "::Shared Path Renewal Program" ALIAS_GEOMETRY    ROUTE XLSXR "XLSXR_2::Renewal Plan" multi_reader_keyword,$(DATASET_KEYWORD_XLSXR_2) TO FME_GENERIC "::Renewal Plan" ALIAS_GEOMETRY    ROUTE XLSXR XLSXR_4::Sheet1 multi_reader_keyword,$(DATASET_KEYWORD_XLSXR_4) TO FME_GENERIC ::Sheet1 ALIAS_GEOMETRY    ROUTE XLSXR "XLSXR_5::Renewal Program 2026-2036" multi_reader_keyword,$(DATASET_KEYWORD_XLSXR_5) TO FME_GENERIC "::Renewal Program 2026-2036" ALIAS_GEOMETRY    ROUTE XLSXR "XLSXR_12::Kerb and Channel Renewal Progra" multi_reader_keyword,$(DATASET_KEYWORD_XLSXR_12) TO FME_GENERIC "::Kerb and Channel Renewal Progra" ALIAS_GEOMETRY    ROUTE XLSXR "XLSXR_13::Year 1 - 2026-27" multi_reader_keyword,$(DATASET_KEYWORD_XLSXR_13) TO FME_GENERIC "::Year 1 - 2026-27" ALIAS_GEOMETRY    ROUTE XLSXR "XLSXR_13::Sealed Roads" multi_reader_keyword,$(DATASET_KEYWORD_XLSXR_13) TO FME_GENERIC "::Sealed Roads" ALIAS_GEOMETRY    ROUTE XLSXR "XLSXR_14::Gravel Re-sheet Renewal Program" multi_reader_keyword,$(DATASET_KEYWORD_XLSXR_14) TO FME_GENERIC "::Gravel Re-sheet Renewal Program" ALIAS_GEOMETRY    ROUTE XLSXR "XLSXR_14::Year 1 - 2026-27" multi_reader_keyword,$(DATASET_KEYWORD_XLSXR_14) TO FME_GENERIC "::Year 1 - 2026-27" ALIAS_GEOMETRY    MERGE_INPUT Yes   OUTPUT ROUTED FEATURE_TYPE *
